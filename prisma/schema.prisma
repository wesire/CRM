generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  businessName  String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customers  Customer[]
  enquiries  Enquiry[]
  quotes     Quote[]
  activities Activity[]
  followUps  FollowUp[]
  settings   UserSettings?
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String?
  businessEmail   String?
  businessPhone   String?
  businessAddress String?
  logoUrl         String?
  accentColor     String  @default("#6366f1")
  quotePrefix     String  @default("QF")
  quoteNextNumber Int     @default(1001)
  currency        String  @default("GBP")
  taxRate         Float   @default(20.0)
  taxLabel        String  @default("VAT")
  followUpDays    Int     @default(3)
  quoteExpiryDays Int     @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  company   String?
  address   String?
  postcode  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enquiries  Enquiry[]
  quotes     Quote[]
  activities Activity[]

  @@index([userId])
}

enum EnquirySource {
  PHONE
  EMAIL
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  WALK_IN
  OTHER
}

enum EnquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CLOSED
}

model Enquiry {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId   String?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  title        String
  description  String?
  source       EnquirySource @default(OTHER)
  status       EnquiryStatus @default(NEW)
  contactName  String?
  contactEmail String?
  contactPhone String?
  quoteId      String?       @unique
  quote        Quote?        @relation(fields: [quoteId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([customerId])
}

enum QuoteStatus {
  DRAFT
  SENT
  OPENED
  REPLIED
  ACCEPTED
  LOST
  EXPIRED
}

model Quote {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  quoteNumber  String      @unique
  title        String
  description  String?
  status       QuoteStatus @default(DRAFT)
  subtotal     Float       @default(0)
  taxRate      Float       @default(20.0)
  taxAmount    Float       @default(0)
  total        Float       @default(0)
  validUntil   DateTime?
  sentAt       DateTime?
  openedAt     DateTime?
  repliedAt    DateTime?
  acceptedAt   DateTime?
  lostAt       DateTime?
  lostReason   String?
  wonReason    String?
  customerNote String?
  internalNote String?
  publicToken  String      @unique @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  enquiry   Enquiry?
  lineItems QuoteLineItem[]
  activities Activity[]
  followUps  FollowUp[]

  @@index([userId])
  @@index([customerId])
  @@index([status])
  @@index([publicToken])
}

model QuoteLineItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  total       Float    @default(0)
  optional    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([quoteId])
}

enum ActivityType {
  ENQUIRY_CREATED
  ENQUIRY_UPDATED
  QUOTE_CREATED
  QUOTE_SENT
  QUOTE_OPENED
  QUOTE_REPLIED
  QUOTE_ACCEPTED
  QUOTE_LOST
  QUOTE_EXPIRED
  QUOTE_UPDATED
  FOLLOW_UP_SCHEDULED
  FOLLOW_UP_COMPLETED
  EMAIL_SENT
  EMAIL_RECEIVED
  NOTE_ADDED
  CUSTOMER_CREATED
}

model Activity {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?    @relation(fields: [customerId], references: [id])
  quoteId     String?
  quote       Quote?       @relation(fields: [quoteId], references: [id])
  type        ActivityType
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([customerId])
  @@index([quoteId])
  @@index([createdAt])
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  SKIPPED
  OVERDUE
}

model FollowUp {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  quoteId     String
  quote       Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  status      FollowUpStatus @default(PENDING)
  dueDate     DateTime
  note        String?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([quoteId])
  @@index([dueDate])
  @@index([status])
}
